{
    "$schema": "https://json.schemastore.org/package.json",
    "name": "@tusente/ichava",
    "version": "2.0.0",
    "description": "SVG Icon Management Package with Vue.js + shadcn-vue Browser (Laravel Integrated)",
    "private": true,
    "type": "module",
    "scripts": {
        "clean": "rm -rf public/* public/.vite 2>/dev/null || true",
        "build": "npm run clean && echo '' && echo '🔨 Building Ichava (dev)...' && NODE_ENV=development vite build",
        "build:prod": "npm run clean && echo '' && echo '🚀 Building Ichava (production)...' && NODE_ENV=production vite build",
        "watch": "echo '' && echo '👀 Watching Ichava for changes...' && vite build --watch",
        "dev": "vite",
        "preview": "vite preview"
    },
    "keywords": [
        "icons",
        "svg",
        "ichava",
        "vue",
        "shadcn-vue",
        "tailwindcss",
        "laravel"
    ],
    "dependencies": {
        "@headlessui/vue": "^1.7.23",
        "@tailwindcss/postcss": "^4.1.17",
        "@tailwindplus/elements": "^1.0.19",
        "@types/node": "^24.10.1",
        "@unovis/ts": "^1.6.2",
        "@unovis/vue": "^1.6.2",
        "@vee-validate/zod": "^4.15.1",
        "@vitejs/plugin-vue": "^6.0.1",
        "@vue/tsconfig": "^0.8.1",
        "@vueuse/core": "^14.1.0",
        "autoprefixer": "^10.4.22",
        "axios": "^1.13.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "embla-carousel-vue": "^8.6.0",
        "lodash": "^4.17.21",
        "lucide-vue-next": "^0.555.0",
        "pinia": "^2.2.0",
        "postcss": "^8.5.6",
        "radix-vue": "^1.9.17",
        "reka-ui": "^2.6.1",
        "tailwind-merge": "^3.4.0",
        "tailwindcss": "^4.1.17",
        "tiny-emitter": "^2.1.0",
        "typescript": "~5.9.3",
        "vaul-vue": "^0.4.1",
        "vee-validate": "^4.15.1",
        "vite": "^7.2.4",
        "vue": "^3.5.24",
        "vue-sonner": "^2.0.9",
        "vue-tsc": "^3.1.4",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@radix-icons/vue": "^1.0.0",
        "@tailwindcss/postcss": "^4.1.17",
        "@types/node": "^24.10.1",
        "@vitejs/plugin-vue": "^6.0.1",
        "@vue/tsconfig": "^0.8.1",
        "autoprefixer": "^10.4.22",
        "postcss": "^8.5.6",
        "sass": "^1.94.2",
        "tailwindcss": "^4.1.17",
        "tailwindcss-animate": "^1.0.7",
        "typescript": "~5.9.3",
        "vite": "^7.2.4",
        "vue-tsc": "^3.1.4"
    }
}

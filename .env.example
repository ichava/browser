# =============================================================================
#  Ichava Browser — example environment configuration
# =============================================================================
#
#  HTTP-layer settings for `ichava/browser` (the SPA + REST API + middleware).
#  Engine keys (`ICHAVA_DATABASE_*`, `ICHAVA_LOGGING_*`, `ICHAVA_QUEUE_*`, etc.)
#  live in `ichava/core`'s .env.example. Copy the keys you need from BOTH
#  packages into your application's .env.
#
#  Reference: github.com/ichava/documentation/docs/environment.md
# =============================================================================

# ----------------------------------------------------------------------------
# Vite dev mode (HMR)
# ----------------------------------------------------------------------------
# Enable Vite's hot-module-reload dev server during local development.
# Auto-disabled in production regardless of this value.
ICHAVA_VITE_DEV=true

# ----------------------------------------------------------------------------
# Browser UI (mounted at /{prefix}/icons)
# ----------------------------------------------------------------------------
# The {prefix} segment is shared with core's REST API (/{prefix}/api/...).
# Lives in core's config (`ichava.prefix`) — set ICHAVA_BROWSER_PREFIX in core
# .env or here; both read the same env var.
ICHAVA_BROWSER_PREFIX=ichava
ICHAVA_BROWSER_PER_PAGE=60
ICHAVA_BROWSER_CACHE=3600

# Enable the bundled <x-ichava::ichava-test-icons> + <x-ichava::ichava-ui-icons>
# demo Blade components.
ICHAVA_TEST_COMPONENT_ENABLED=true

# ----------------------------------------------------------------------------
# Multi-domain support
# ----------------------------------------------------------------------------
# Empty (default) → routes work on every domain.
# Comma-separated list → restrict to listed domains, e.g. `app.test,admin.test`.
ICHAVA_DOMAINS=

# ----------------------------------------------------------------------------
# REST API behaviour
# ----------------------------------------------------------------------------
ICHAVA_API_PRETTY_PRINT=true
ICHAVA_API_CORS_ENABLED=true
ICHAVA_API_CORS_ORIGINS=*

# ----------------------------------------------------------------------------
# HTTP request size guard (bytes)
# ----------------------------------------------------------------------------
# Hard cap enforced by IchavaApiSecurity middleware. Default 1 MiB.
ICHAVA_MAX_REQUEST_SIZE=1048576

# ----------------------------------------------------------------------------
# Rate limiting (requests per minute)
# ----------------------------------------------------------------------------
# Master toggle — when false, all per-route limits are no-ops.
ICHAVA_RATE_LIMITING_ENABLED=false
# Per-bucket limits (only enforced when ICHAVA_RATE_LIMITING_ENABLED=true).
ICHAVA_BROWSER_RATE_LIMIT=300
ICHAVA_API_RATE_LIMIT=600
# Global floor applied to the `ichava.api` middleware group on top of
# per-endpoint limits (independent of the master toggle).
ICHAVA_API_FLOOR=300
